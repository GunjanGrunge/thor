{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NormalizedRecord",
  "type": "object",
  "required": [
    "id",
    "domain",
    "source",
    "record_type",
    "title",
    "content"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "domain": {
      "type": "string",
      "enum": [
        "workout",
        "nutrition",
        "supplements",
        "combined"
      ]
    },
    "source": {
      "type": "string"
    },
    "record_type": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "grounding_urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
